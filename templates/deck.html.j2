<script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.js"></script>
<script>
Reveal.initialize({
  hash: false, progress: true, controls: true, center: false,
  transition: 'slide', transitionSpeed: 'default',
  autoSlide: 0, loop: false, width: 1280, height: 720,
  slideNumber: 'c/t', fragments: true,
  keyboard: true,
});

// Auto-fit: shrink slide-inner font until content stops overflowing
(function () {
  function fitSlide(section) {
    var inner = section.querySelector('.slide-inner');
    if (!inner) return;
    var minEm = 0.72; // never go below 72% of base
    var step   = 0.04;
    var cur    = 1.0;
    inner.style.fontSize = cur + 'em';
    while (inner.scrollHeight > inner.clientHeight + 4 && cur > minEm) {
      cur = Math.round((cur - step) * 100) / 100;
      inner.style.fontSize = cur + 'em';
    }
  }
  Reveal.on('ready', function () {
    document.querySelectorAll('.reveal .slides section').forEach(fitSlide);
  });
  Reveal.on('slidechanged', function (e) {
    if (e.currentSlide) fitSlide(e.currentSlide);
  });
})();

// OBS-compatible auto-advance + fragment auto-reveal
// No focus/visibility dependency — works in CEF / OBS Browser Source
(function () {
  var sections = document.querySelectorAll('.reveal .slides section');
  var timings = [];
  sections.forEach(function (s) {
    timings.push(parseInt(s.getAttribute('data-autoslide') || '5000', 10));
  });
  if (!timings.length) return;

  var idx       = 0;
  var slideTimer = null;
  var fragTimers = [];
  var advancing  = false; // prevent slidechanged from double-scheduling

  // Reveal all .fragment elements in a slide with fade-up stagger
  function revealFragments(slideEl) {
    fragTimers.forEach(clearTimeout);
    fragTimers = [];
    var frags = slideEl ? slideEl.querySelectorAll('.fragment') : [];
    frags.forEach(function (f, i) {
      fragTimers.push(setTimeout(function () {
        f.classList.add('visible', 'current-fragment');
      }, (i + 1) * 400));
    });
  }

  function scheduleAdvance() {
    clearTimeout(slideTimer);
    if (idx >= timings.length - 1) return;
    slideTimer = setTimeout(function () {
      advancing = true;
      idx++;
      Reveal.slide(idx);
      advancing = false;
      revealFragments(sections[idx]);
      scheduleAdvance();
    }, timings[idx]);
  }

  Reveal.on('ready', function () {
    revealFragments(sections[0]);
    scheduleAdvance();
  });

  // Manual navigation resets everything cleanly
  Reveal.on('slidechanged', function (e) {
    if (advancing) return;
    idx = e.indexh;
    revealFragments(sections[idx]);
    scheduleAdvance();
  });
})();

(function () {
  var labels = {{ price_labels }};
  var values = {{ price_values }};
  var ma20   = {{ ma20 if ma20 is not none else 'null' }};
  var ma50   = {{ ma50 if ma50 is not none else 'null' }};

  if (!labels || !labels.length) return;
  var canvas = document.getElementById('priceChart');
  if (!canvas) return;

  var first = values[0], last = values[values.length - 1];
  var lineColor = last >= first ? '#10b981' : '#f43f5e';
  var fillColor = last >= first ? 'rgba(16,185,129,0.07)' : 'rgba(244,63,94,0.07)';

  var datasets = [{
    label: '收盘价', data: values,
    borderColor: lineColor, backgroundColor: fillColor,
    borderWidth: 2.5, pointRadius: 0, pointHoverRadius: 5,
    fill: true, tension: 0.35, order: 1,
  }];
  if (ma20 !== null) datasets.push({
    label: 'MA20', data: Array(labels.length).fill(ma20),
    borderColor: '#f59e0b', borderWidth: 1.3, borderDash: [6,4],
    pointRadius: 0, fill: false, tension: 0, order: 2,
  });
  if (ma50 !== null) datasets.push({
    label: 'MA50', data: Array(labels.length).fill(ma50),
    borderColor: '#8b5cf6', borderWidth: 1.3, borderDash: [4,3],
    pointRadius: 0, fill: false, tension: 0, order: 3,
  });

  new Chart(canvas, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { intersect: false, mode: 'index' },
      plugins: {
        legend: {
          display: true, position: 'top', align: 'end',
          labels: { color: '#64748b', font: { size: 10 }, boxWidth: 20, padding: 10, usePointStyle: true, pointStyleWidth: 14 }
        },
        tooltip: {
          backgroundColor: '#1a2235', borderColor: '#1f2d40', borderWidth: 1,
          titleColor: '#94a3b8', bodyColor: '#f1f5f9', padding: 10,
          callbacks: { label: ctx => ' ' + ctx.dataset.label + ': $' + ctx.parsed.y.toFixed(2) }
        }
      },
      scales: {
        x: { ticks: { color: '#64748b', maxTicksLimit: 7, font: { size: 10 } }, grid: { color: 'rgba(31,45,64,0.9)' }, border: { color: '#1f2d40' } },
        y: { position: 'right', ticks: { color: '#64748b', font: { size: 10 }, callback: v => '$' + v.toFixed(0) }, grid: { color: 'rgba(31,45,64,0.9)' }, border: { color: '#1f2d40' } }
      }
    }
  });
})();
</script>
</body>
</html>

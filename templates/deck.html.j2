<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"/>
<title>{{ title }}</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/theme/black.css"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root {
    --c-bg:        #080d14;
    --c-surface:   #111827;
    --c-surface2:  #1a2235;
    --c-border:    #1f2d40;
    --c-accent:    #3b82f6;
    --c-accent-lo: rgba(59,130,246,0.12);
    --c-green:     #10b981;
    --c-red:       #f43f5e;
    --c-gold:      #f59e0b;
    --c-purple:    #8b5cf6;
    --c-text:      #f1f5f9;
    --c-muted:     #64748b;
    --c-muted2:    #94a3b8;
  }

  .reveal {
    background: var(--c-bg);
    font-family: 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', Arial, sans-serif;
  }
  .reveal::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle, #1a2540 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.45;
    pointer-events: none;
    z-index: 0;
  }
  .reveal .slides { z-index: 1; }
  .reveal .slides section { text-align: left; height: 100%; }

  /* ── Footer ── */
  .slide-footer {
    position: absolute;
    bottom: 16px; left: 60px; right: 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.42em;
    color: var(--c-muted);
    border-top: 1px solid var(--c-border);
    padding-top: 7px;
    letter-spacing: 0.08em;
  }
  .footer-ticker { font-weight: 800; color: var(--c-accent); letter-spacing: 0.18em; }

  /* ── Common layout ── */
  .slide-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 30px 60px 52px;
    box-sizing: border-box;
    position: relative;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    font-size: 0.46em;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 13px;
    border-radius: 4px;
    margin-bottom: 10px;
    width: fit-content;
    background: var(--c-accent-lo);
    color: var(--c-accent);
    border: 1px solid rgba(59,130,246,0.25);
  }
  .tag.red    { background: rgba(244,63,94,0.1);  color: var(--c-red);    border-color: rgba(244,63,94,0.28); }
  .tag.gold   { background: rgba(245,158,11,0.1); color: var(--c-gold);   border-color: rgba(245,158,11,0.28); }
  .tag.green  { background: rgba(16,185,129,0.1); color: var(--c-green);  border-color: rgba(16,185,129,0.28); }
  .tag.purple { background: rgba(139,92,246,0.1); color: var(--c-purple); border-color: rgba(139,92,246,0.28); }

  .slide-headline {
    font-size: 1.45em;
    font-weight: 800;
    color: var(--c-text);
    line-height: 1.25;
    margin: 0 0 12px;
  }

  /* ── Cover ── */
  .cover-wrap { display: flex; height: 100%; box-sizing: border-box; }
  .cover-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 50px 40px 50px 60px;
  }
  .cover-right {
    width: 268px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
    padding: 36px 48px 36px 0;
  }
  .cover-eyebrow {
    font-size: 0.5em;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--c-accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .cover-headline {
    font-size: 2em;
    font-weight: 900;
    color: var(--c-text);
    line-height: 1.2;
    margin: 0 0 16px;
  }
  .cover-divider {
    width: 44px; height: 3px;
    background: linear-gradient(90deg, var(--c-accent), transparent);
    border-radius: 2px;
    margin-bottom: 12px;
  }
  .cover-company { font-size: 0.7em; color: var(--c-muted2); margin-bottom: 14px; }
  .cover-hook {
    font-size: 0.72em;
    color: var(--c-gold);
    line-height: 1.55;
    padding: 10px 14px;
    border-left: 3px solid var(--c-gold);
    background: rgba(245,158,11,0.07);
    border-radius: 0 6px 6px 0;
  }

  /* price widget */
  .price-widget {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 14px;
    padding: 18px 20px;
    text-align: center;
  }
  .pw-label { font-size: 0.46em; color: var(--c-muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 7px; }
  .pw-price { font-size: 1.85em; font-weight: 900; color: var(--c-text); line-height: 1; margin-bottom: 7px; }
  .pw-change {
    display: inline-block; font-size: 0.7em; font-weight: 700;
    padding: 3px 12px; border-radius: 12px;
  }
  .pw-change.up   { background: rgba(16,185,129,0.15); color: var(--c-green); }
  .pw-change.down { background: rgba(244,63,94,0.15);  color: var(--c-red); }

  .cover-info-card {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: 10px; padding: 11px 16px;
    text-align: center; font-size: 0.5em; color: var(--c-muted2);
  }
  .cover-info-card strong {
    display: block; font-size: 1.3em; font-weight: 700;
    color: var(--c-text); margin-bottom: 2px;
  }

  /* ── Callout box (market_overview, financials) ── */
  .callout-box {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-top: 14px;
    padding: 13px 16px;
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.22);
    border-radius: 8px;
  }
  .callout-icon { font-size: 1em; color: var(--c-accent); flex-shrink: 0; margin-top: 1px; }
  .callout-text { font-size: 0.78em; color: var(--c-text); line-height: 1.55; }

  /* ── Stats grid ── */
  .stats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-top: 12px; }
  .stat-card {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-left: 3px solid var(--c-border); border-radius: 10px; padding: 12px 14px;
  }
  .stat-card.a { border-left-color: var(--c-accent); }
  .stat-card.g { border-left-color: var(--c-green);  }
  .stat-card.r { border-left-color: var(--c-red);    }
  .stat-card.o { border-left-color: var(--c-gold);   }
  .stat-label { font-size: 0.46em; color: var(--c-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 5px; }
  .stat-value { font-size: 1.08em; font-weight: 700; color: var(--c-text); }
  .stat-value.up   { color: var(--c-green); }
  .stat-value.down { color: var(--c-red); }

  /* ── Chart ── */
  .chart-wrap {
    width: 100%; height: 240px; position: relative; margin-top: 10px;
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: 10px; padding: 8px 12px 6px; box-sizing: border-box;
  }

  /* ── Direction badge (price_action, outlook) ── */
  .direction-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 20px; border-radius: 22px; font-weight: 800;
    font-size: 0.78em; margin-bottom: 12px; letter-spacing: 0.05em;
  }
  .direction-badge.bullish { background: rgba(16,185,129,0.14); border: 1px solid rgba(16,185,129,0.38); color: var(--c-green); }
  .direction-badge.bearish { background: rgba(244,63,94,0.14);  border: 1px solid rgba(244,63,94,0.38);  color: var(--c-red); }
  .direction-badge.neutral { background: rgba(245,158,11,0.14); border: 1px solid rgba(245,158,11,0.38); color: var(--c-gold); }

  /* ── Bullets ── */
  .bullets { list-style: none; margin: 0; padding: 0; }
  .bullets li {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 9px 0; border-bottom: 1px solid var(--c-border);
    font-size: 0.78em; color: var(--c-text); line-height: 1.55;
  }
  .bullets li:last-child { border-bottom: none; }
  .bullet-num {
    min-width: 21px; height: 21px; border-radius: 50%;
    background: var(--c-accent-lo); border: 1px solid rgba(59,130,246,0.3);
    color: var(--c-accent); font-size: 0.8em; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
  }
  .bullet-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--c-accent); margin-top: 7px; flex-shrink: 0;
  }
  .bullet-dot.r { background: var(--c-red); }
  .bullet-dot.g { background: var(--c-green); }
  .bullet-dot.o { background: var(--c-gold); }

  /* ── Key Points (title + body) ── */
  .kp-list { list-style: none; margin: 0; padding: 0; }
  .kp-item {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid var(--c-border);
  }
  .kp-item:last-child { border-bottom: none; }
  .kp-tag-dot {
    min-width: 8px; height: 8px; border-radius: 50%;
    margin-top: 8px; flex-shrink: 0;
  }
  .kp-tag-dot.bull { background: var(--c-green); }
  .kp-tag-dot.bear { background: var(--c-red); }
  .kp-tag-dot.neutral { background: var(--c-gold); }
  .kp-content { flex: 1; }
  .kp-title { font-size: 0.82em; font-weight: 700; color: var(--c-text); margin-bottom: 3px; }
  .kp-body  { font-size: 0.72em; color: var(--c-muted2); line-height: 1.5; }
  .kp-badge {
    font-size: 0.52em; font-weight: 700; padding: 2px 8px;
    border-radius: 10px; flex-shrink: 0; margin-top: 4px; align-self: flex-start;
  }
  .kp-badge.bull { background: rgba(16,185,129,0.15); color: var(--c-green); }
  .kp-badge.bear { background: rgba(244,63,94,0.15);  color: var(--c-red); }
  .kp-badge.neutral { background: rgba(245,158,11,0.15); color: var(--c-gold); }

  /* ── Metrics grid (financials) ── */
  .metrics-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 9px; margin-top: 10px; }
  .metric-card {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: 8px; padding: 11px 13px;
  }
  .metric-label { font-size: 0.48em; color: var(--c-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 5px; }
  .metric-value { font-size: 0.98em; font-weight: 700; color: var(--c-text); }
  .metric-value.up   { color: var(--c-green); }
  .metric-value.down { color: var(--c-red); }
  .metric-trend { font-size: 0.75em; margin-right: 3px; }

  /* ── Risk cards with severity ── */
  .card-list { display: flex; flex-direction: column; gap: 8px; margin-top: 8px; }
  .risk-card-v2 {
    display: flex; align-items: flex-start; gap: 10px;
    background: rgba(244,63,94,0.05); border: 1px solid rgba(244,63,94,0.16);
    border-left: 3px solid var(--c-red); border-radius: 8px; padding: 10px 14px;
  }
  .risk-severity {
    font-size: 0.52em; font-weight: 800; padding: 2px 8px; border-radius: 8px;
    flex-shrink: 0; margin-top: 2px;
  }
  .risk-severity.high   { background: rgba(244,63,94,0.2);  color: var(--c-red); }
  .risk-severity.medium { background: rgba(245,158,11,0.2); color: var(--c-gold); }
  .risk-severity.low    { background: rgba(16,185,129,0.2); color: var(--c-green); }
  .risk-content { flex: 1; }
  .risk-title { font-size: 0.78em; font-weight: 700; color: var(--c-text); margin-bottom: 3px; }
  .risk-body  { font-size: 0.68em; color: var(--c-muted2); line-height: 1.5; }

  /* ── Catalyst cards ── */
  .catalyst-card-v2 {
    display: flex; align-items: flex-start; gap: 10px;
    border-radius: 8px; padding: 10px 14px;
  }
  .catalyst-card-v2.positive {
    background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.18);
    border-left: 3px solid var(--c-green);
  }
  .catalyst-card-v2.negative {
    background: rgba(244,63,94,0.06); border: 1px solid rgba(244,63,94,0.18);
    border-left: 3px solid var(--c-red);
  }
  .cat-icon { font-size: 0.9em; flex-shrink: 0; margin-top: 2px; }
  .cat-icon.pos { color: var(--c-green); }
  .cat-icon.neg { color: var(--c-red); }
  .cat-content { flex: 1; }
  .cat-event { font-size: 0.78em; font-weight: 700; color: var(--c-text); margin-bottom: 3px; }
  .cat-meta  { font-size: 0.62em; color: var(--c-muted2); }
  .cat-impact {
    font-size: 0.52em; font-weight: 700; padding: 2px 8px; border-radius: 8px;
    flex-shrink: 0; margin-top: 3px; align-self: flex-start;
  }
  .cat-impact.large  { background: rgba(244,63,94,0.15); color: var(--c-red); }
  .cat-impact.medium { background: rgba(245,158,11,0.15); color: var(--c-gold); }
  .cat-impact.small  { background: rgba(16,185,129,0.12); color: var(--c-green); }

  /* ── Outlook: range + scenarios ── */
  .range-box {
    display: inline-flex; flex-direction: column; align-items: center;
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: 10px; padding: 10px 24px; margin-bottom: 14px;
  }
  .range-label { font-size: 0.48em; color: var(--c-muted); letter-spacing: 0.1em; margin-bottom: 4px; }
  .range-values { font-size: 1.1em; font-weight: 800; color: var(--c-text); }

  .scenarios { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-top: 4px; }
  .scenario {
    border-radius: 10px; padding: 14px 16px;
  }
  .scenario.bull {
    background: rgba(16,185,129,0.07); border: 1px solid rgba(16,185,129,0.22);
    border-top: 3px solid var(--c-green);
  }
  .scenario.bear {
    background: rgba(244,63,94,0.07); border: 1px solid rgba(244,63,94,0.22);
    border-top: 3px solid var(--c-red);
  }
  .scenario-label {
    font-size: 0.5em; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 6px;
  }
  .scenario.bull .scenario-label { color: var(--c-green); }
  .scenario.bear .scenario-label { color: var(--c-red); }
  .scenario.base .scenario-label { color: var(--c-accent); }
  .scenario-condition { font-size: 0.72em; color: var(--c-text); line-height: 1.5; margin-bottom: 6px; }
  .scenario-target { font-size: 0.7em; font-weight: 700; }
  .scenario.bull .scenario-target { color: var(--c-green); }
  .scenario.bear .scenario-target { color: var(--c-red); }
  .scenario.base .scenario-target { color: var(--c-accent); }

  /* ── Summary ── */
  .summary-quote {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-left: 4px solid var(--c-accent); border-radius: 10px;
    padding: 20px 24px 20px 26px; margin-top: 12px; position: relative;
  }
  .summary-quote::before {
    content: '"'; position: absolute; top: -10px; left: 16px;
    font-size: 3em; color: var(--c-accent); opacity: 0.22;
    font-family: Georgia, serif; line-height: 1;
  }
  .summary-text { font-size: 1em; font-weight: 600; color: var(--c-text); line-height: 1.65; }

  .verdict-row { display: flex; gap: 10px; margin-top: 12px; align-items: center; }
  .verdict-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 18px; border-radius: 20px; font-weight: 800; font-size: 0.72em;
  }
  .verdict-badge.bullish { background: rgba(16,185,129,0.14); border: 1px solid rgba(16,185,129,0.38); color: var(--c-green); }
  .verdict-badge.bearish { background: rgba(244,63,94,0.14);  border: 1px solid rgba(244,63,94,0.38);  color: var(--c-red); }
  .verdict-badge.neutral { background: rgba(245,158,11,0.14); border: 1px solid rgba(245,158,11,0.38); color: var(--c-gold); }

  .action-box {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 10px; padding: 11px 14px;
    background: rgba(59,130,246,0.07); border: 1px solid rgba(59,130,246,0.2);
    border-radius: 8px;
  }
  .action-label { font-size: 0.5em; font-weight: 700; color: var(--c-accent); letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; margin-top: 2px; }
  .action-text  { font-size: 0.74em; color: var(--c-text); line-height: 1.55; }

  .disclaimer {
    font-size: 0.44em; color: var(--c-muted); margin-top: 14px;
    line-height: 1.6; padding: 8px 12px;
    background: rgba(255,255,255,0.03); border: 1px solid var(--c-border); border-radius: 6px;
  }

  /* Reveal overrides */
  .reveal .progress { color: var(--c-accent); height: 3px; }
  .reveal .controls button { color: var(--c-accent); }
</style>
</head>
<body>
<div class="reveal">
<div class="slides">

{% for slide in slides %}

{# ── Cover ── #}
{% if slide.type == 'cover' %}
<section data-autoslide="{{ slide.autoslide_ms | default(30000) }}">
  <div class="cover-wrap">
    <div class="cover-left">
      <div class="cover-eyebrow">{{ ticker }} &nbsp;·&nbsp; 本周深度分析</div>
      <div class="cover-headline">{{ slide.headline }}</div>
      <div class="cover-divider"></div>
      <div class="cover-company">{{ company_name }}&nbsp;&nbsp;·&nbsp;&nbsp;{{ slide.subtitle if slide.subtitle else '每周股票点评' }}</div>
      {% if slide.hook %}
      <div class="cover-hook">{{ slide.hook }}</div>
      {% endif %}
    </div>
    <div class="cover-right">
      <div class="price-widget">
        <div class="pw-label">当前价格</div>
        <div class="pw-price">${{ current_price }}</div>
        <div class="pw-change {{ 'up' if price_change_pct >= 0 else 'down' }}">{{ price_sign }}{{ price_change_pct }}%</div>
      </div>
      <div class="cover-info-card"><strong>{{ market_cap_str }}</strong>市值</div>
      <div class="cover-info-card"><strong>Fwd PE {{ pe_ratio if pe_ratio else 'N/A' }}</strong>预期市盈率</div>
    </div>
  </div>
  <div class="slide-footer">
    <span class="footer-ticker">{{ ticker }}</span>
    <span>股票深度点评</span>
  </div>
</section>

{# ── Market Overview ── #}
{% elif slide.type == 'market_overview' %}
<section data-autoslide="{{ slide.autoslide_ms | default(30000) }}">
  <div class="slide-inner">
    <div class="tag">市场概览</div>
    <div class="slide-headline">{{ slide.headline }}</div>
    <div class="stats-grid">
      <div class="stat-card a"><div class="stat-label">当前价格</div><div class="stat-value">${{ current_price }}</div></div>
      <div class="stat-card {{ 'g' if price_change_pct >= 0 else 'r' }}">
        <div class="stat-label">日涨跌幅</div>
        <div class="stat-value {{ 'up' if price_change_pct >= 0 else 'down' }}">{{ price_sign }}{{ price_change_pct }}%</div>
      </div>
      <div class="stat-card o"><div class="stat-label">市值</div><div class="stat-value">{{ market_cap_str }}</div></div>
      <div class="stat-card a"><div class="stat-label">预期市盈率 (Fwd PE)</div><div class="stat-value">{{ pe_ratio if pe_ratio else 'N/A' }}</div></div>
      <div class="stat-card g"><div class="stat-label">分析师目标价</div><div class="stat-value">{{ analyst_target if analyst_target else 'N/A' }}</div></div>
      <div class="stat-card o"><div class="stat-label">Beta</div><div class="stat-value">{{ beta if beta else 'N/A' }}</div></div>
    </div>
    {% if slide.callout %}
    <div class="callout-box fragment fade-up">
      <div class="callout-icon">◈</div>
      <div class="callout-text">{{ slide.callout }}</div>
    </div>
    {% endif %}
  </div>
  <div class="slide-footer"><span class="footer-ticker">{{ ticker }}</span><span>市场数据</span></div>
</section>

{# ── Price Action ── #}
{% elif slide.type == 'price_action' %}
<section data-autoslide="{{ slide.autoslide_ms | default(30000) }}">
  <div class="slide-inner">
    <div class="tag gold">价格走势</div>
    <div class="slide-headline">{{ slide.headline }}</div>
    {% if slide.signal %}
    {% set sig = slide.signal | lower %}
    <div class="direction-badge {{ sig }}">
      {{ '▲' if sig == 'bullish' else '▼' if sig == 'bearish' else '◆' }}
      {{ '技术偏多' if sig == 'bullish' else '技术偏空' if sig == 'bearish' else '技术中性' }}
    </div>
    {% endif %}
    <div class="chart-wrap"><canvas id="priceChart"></canvas></div>
    {% if slide.bullets %}
    <ul class="bullets" style="margin-top:8px">
      {% for b in slide.bullets %}
